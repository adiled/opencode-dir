#!/bin/bash
set -e

while read local_ref local_sha remote_ref remote_sha; do
  if [ "$remote_ref" = "refs/heads/main" ]; then
    # Idempotency: skip if package.json already in HEAD commit
    if git diff-tree --no-commit-id --name-only -r HEAD | grep -q '^package\.json$'; then
      exit 0
    fi
    npm version patch --no-git-tag-version
    VERSION=$(node -p "require('./package.json').version")
    git add package.json
    git commit --amend --no-edit
    # Inner push delivers the amended commit
    git push origin main
    echo "Pushed v${VERSION}"
    # Abort outer push (stale SHA) — inner push already delivered
    exit 1
  fi
done
